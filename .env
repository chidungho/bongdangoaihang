PORT=3000
NODE_ENV=development
JWT_SECRET=replace-with-strong-secret
MONGODB_URI=mongodb://127.0.0.1:27017/bongdangoaihang
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@bongdangoaihang.com
ADMIN_PASSWORD=12345678
ADMIN_PATH=/he-thong/quan-tri
CONTRIBUTOR_PATH=/he-thong/cong-tac-vien
SCRAPE_INTERVAL_MS=86400000
SCRAPE_ON_STARTUP=true
MATCH_PROVIDER=auto
